# eDNA LPT API Configuration
# Copy this file to .env and update values for your environment

# JWT Configuration (Phase 6A)
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Database Configuration (Phase 6B - for production)
# DATABASE_URL=postgresql://user:password@localhost/ednalpt_db

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=False

# Logging
LOG_LEVEL=INFO

# Monitoring (Phase 5C)
METRICS_ENABLED=True
PROMETHEUS_PORT=9090
